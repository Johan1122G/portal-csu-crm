{
  "name": "bex-crm",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "node server.js",
    "lint": "next lint",
    "postinstall": "prisma generate",
    "test:db": "dotenv -e .env.test -- prisma migrate deploy",
    "test": "npm run test:db && vitest run",
    "test:watch": "npm run test:db && vitest",
    "test:e2e": "npm run test:db && dotenv -e .env.test -- playwright test",
    "test:e2e:ui": "npm run test:db && dotenv -e .env.test -- playwright test --ui"
  },
  "dependencies": {
    "@fluentui/react-components": "^9.74.1",
    "@fluentui/react-icons": "^2.0.330",
    "@hookform/resolvers": "^5.4.0",
    "@prisma/client": "^5.22.0",
    "date-fns": "^4.4.0",
    "exceljs": "^4.4.0",
    "jszip": "^3.10.1",
    "next": "14.2.35",
    "next-auth": "^5.0.0-beta.31",
    "papaparse": "^5.5.3",
    "react": "^18",
    "react-dom": "^18",
    "react-hook-form": "^7.79.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^20",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "cross-env": "^10.1.0",
    "dotenv-cli": "^11.0.0",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "prisma": "^5.22.0",
    "tsx": "^4.22.4",
    "typescript": "^5",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.9"
  }
}
