generator client {
  provider      = "prisma-client-js"
  // "native" para dev local; "debian-openssl-3.0.x" para el runner de CI y Azure App Service (Linux).
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ACCOUNT (D365: account) ─────────────────────────────────────────────────
model Account {
  id String @id @default(cuid())

  // Sección 1 — Información General
  // D365 field names as comments for export mapping
  name                 String // D365: name
  accountnumber        String  @unique // D365: accountnumber (NIT)
  cr_bex_estadocliente String  @default("Activo") // D365: custom — Activo | Inactivo | Prospecto | En riesgo
  cr_bex_glpientityid  String? @unique // custom — id de la entidad en GLPI (para sync idempotente)
  industrycode         String? // D365: industrycode
  address1_city        String? // D365: address1_city
  address1_country     String  @default("Colombia") // D365: address1_country
  cr_bex_tamanoempresa String? // D365: custom — Micro | Pequeña | Mediana | Grande | Enterprise
  websiteurl           String? // D365: websiteurl
  cr_bex_primernegocio DateTime? // D365: custom

  // Sección 4 — Conocimiento del Cliente
  cr_bex_principalesretos      String?
  cr_bex_principalesdolores    String?
  cr_bex_objetivosestrategicos String?
  cr_bex_expectativasbext      String?
  cr_bex_riesgosidentificados  String?
  cr_bex_oportunidades         String?

  // Sección 5 — Soporte
  cr_bex_tienebolsahoras        Boolean @default(false)
  cr_bex_horascontratadas       Int?
  cr_bex_horasconsumidas        Int?
  cr_bex_glpiticketsincluidos   String? // custom — JSON de IDs de tickets GLPI que componen las horas consumidas del contrato actual
  cr_bex_nivelsatisfaccion      Int? // 0-10
  cr_bex_principalessolicitudes String?

  // Sección 5 — Customer Success
  cr_bex_niveladopcion             String? // Bajo | Medio | Alto | Óptimo
  cr_bex_clienteestrategico        Boolean @default(false)
  cr_bex_casoexito                 Boolean @default(false)
  cr_bex_potencialcrecimiento      String? // Bajo | Medio | Alto
  cr_bex_acompanamientoprioritario Boolean @default(false)
  cr_bex_comentarioscs             String?

  // Métricas manuales reportadas por el CSM (conviven con las calculadas de GLPI)
  cr_bex_nps               Int? // NPS reportado
  cr_bex_csatmanual        Float? // CSAT reportado (manual)
  cr_bex_slacumplimiento   Int? // % cumplimiento SLA reportado (manual)
  cr_bex_ultimainteraccion DateTime? // última interacción reportada (manual)

  // Sección 6 — Observaciones Generales
  description String? // D365: description

  // Timestamps
  createdon  DateTime @default(now()) // D365: createdon
  modifiedon DateTime @updatedAt // D365: modifiedon

  // Relations
  contacts       Contact[]
  relationships  BextRelationship[]
  glpiFacts      GlpiTicketFact[]
  insightThreads InsightThread[]
  insightFindings InsightFinding[]
  teamsMeetings  TeamsMeetingCache[]
  tasks            Task[]
  playbookRuns     PlaybookRun[]
  ticketEmbeddings TicketEmbedding[]
  deliverables     Deliverable[]
  products      ProductService[]
  activities    CSActivity[]
  opportunities OpportunityRecommendation[]

  @@map("accounts")
}

// ─── CONTACT (D365: contact) ──────────────────────────────────────────────────
model Contact {
  id        String  @id @default(cuid())
  accountId String
  account   Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  cr_bex_tipocontacto String // Principal | Ejecutivo | Técnico | Operativo | Financiero | Otro
  fullname            String // D365: fullname
  jobtitle            String? // D365: jobtitle
  telephone1          String? // D365: telephone1
  emailaddress1       String // D365: emailaddress1

  createdon  DateTime @default(now())
  modifiedon DateTime @updatedAt

  @@map("contacts")
}

// ─── BEXT RELATIONSHIP (D365: connection / systemuser relation) ───────────────
// Mapea las personas de BEX que atienden al cliente (Ejecutivo Comercial, GP, Líder Técnico)
model BextRelationship {
  id        String  @id @default(cuid())
  accountId String
  account   Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  cr_bex_rolbext              String // Ejecutivo Comercial | Gerente de Proyecto | Líder Técnico
  cr_bex_nombrepersona        String
  cr_bex_frecuenciacontacto   String? // Diaria | Semanal | Quincenal | Mensual | Trimestral
  cr_bex_nivelrelacionamiento String? // Operativo | Táctico | Estratégico
  cr_bex_ultimareunion        DateTime?
  cr_bex_proximareunion       DateTime?
  cr_bex_motivoultimocontacto String?

  createdon  DateTime @default(now())
  modifiedon DateTime @updatedAt

  @@map("bext_relationships")
}

// ─── PRODUCT SERVICE (D365: contract / contractdetail) ───────────────────────
model ProductService {
  id        String  @id @default(cuid())
  accountId String
  account   Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  title                   String // Razón Social Cliente (denormalizado para export)
  cr_bex_lineanegocio     String? // Managed Services | Cloud | Seguridad | Desarrollo | Licenciamiento
  cr_bex_productoservicio String
  statecode               String  @default("Activo") // D365: statecode — Activo | Suspendido | Cancelado | En renovación
  activeon                DateTime? // D365: activeon (fecha inicio)
  expireson               DateTime? // D365: expireson (fecha renovación)
  cr_bex_valorcontrato    Float? // valor del contrato
  cr_bex_tipofacturacion  String? // Mensual | Anual | Único pago | ...
  cr_bex_responsablebext  String?
  cr_bex_observaciones    String?

  createdon  DateTime @default(now())
  modifiedon DateTime @updatedAt

  @@map("product_services")
}

// ─── CS ACTIVITY (D365: activitypointer — phonecall, email, appointment, task) ─
model CSActivity {
  id        String  @id @default(cuid())
  accountId String
  account   Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  scheduledstart         DateTime // D365: scheduledstart (Fecha Gestión)
  cr_bex_tipogestion     String // Llamada | Encuesta | Entrevista | Correo | Reunión | Hallazgo | Oportunidad | Recomendación
  cr_bex_responsablecs   String?
  cr_bex_contactocliente String?
  cr_bex_canal           String? // Teléfono | Email | Teams | Presencial | WhatsApp
  subject                String? // D365: subject (Tema / Motivo)
  description            String? // D365: description (Hallazgo / Voz del Cliente)
  cr_bex_oportunidad     String? // Oportunidad / Recomendación
  cr_bex_areaescalar     String? // Comercial | Técnico | Soporte | Dirección
  statecode              String  @default("Completada") // Pendiente | En proceso | Completada | Cancelada

  createdon  DateTime @default(now())
  modifiedon DateTime @updatedAt

  @@map("cs_activities")
}

// ─── CATALOG (valores de listas desplegables, editables por el CSM) ───────────
model Catalog {
  id         String   @id @default(cuid())
  key        String // ROLES_BEXT | AREAS_ESCALAR | TIPOS_GESTION | ...
  value      String
  sortOrder  Int      @default(0)
  active     Boolean  @default(true)
  createdon  DateTime @default(now())
  modifiedon DateTime @updatedAt

  @@unique([key, value])
  @@index([key])
  @@map("catalogs")
}

// ─── OPPORTUNITY / RECOMMENDATION (D365: opportunity — simplified) ────────────
model OpportunityRecommendation {
  id        String  @id @default(cuid())
  accountId String
  account   Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  createdon              DateTime @default(now()) // D365: createdon
  cr_bex_origen          String   @default("Gestión CS") // Gestión CS | Reunión | Encuesta | Soporte | Otro
  name                   String // D365: name (Descripción)
  cr_bex_tipo            String? // Comercial | Operativa | Producto | Soporte | Escalamiento
  cr_bex_impacto         String? // Alto | Medio | Bajo
  prioritycode           String? // D365: prioritycode — Alta | Media | Baja
  cr_bex_responsable     String? // Responsable / Director
  cr_bex_accionrequerida String?
  estimatedclosedate     DateTime? // D365: estimatedclosedate (Fecha Compromiso)
  statecode              String   @default("Pendiente") // Pendiente | En proceso | Completada | Cancelada

  // Servicio/producto del catálogo BEXT asociado (#5 — upsell)
  serviceCatalogItemId String?
  serviceCatalogItem   ServiceCatalogItem? @relation(fields: [serviceCatalogItemId], references: [id])

  modifiedon DateTime @updatedAt

  @@map("opportunities")
}

// ─── GLPI TICKET FACT (tabla de hechos para analítica) ───────────────────────────
// Réplica desnormalizada de los tickets de GLPI por cliente, poblada por el sync.
// Habilita agregaciones rápidas (por categoría, tendencias, CSAT) sin golpear GLPI.
model GlpiTicketFact {
  id        String  @id @default(cuid())
  accountId String
  account   Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  glpiTicketId    Int
  subject         String?
  content         String? // descripción del ticket (sin HTML, truncada) para Q&A con IA
  category        String? // ITILCategory completename (jerárquico "A > B")
  status          Int // GLPI: 1-4 abiertos, 5 resuelto, 6 cerrado
  openedAt        DateTime?
  closedAt        DateTime?
  resolutionHours Float? // (solución/cierre) − apertura, en horas
  actiontimeHours Float? // actiontime (duración total) en horas
  satisfaction    Int? // CSAT 1-5 (null si sin encuesta)
  isLate          Boolean @default(false) // GLPI: se superó el tiempo de resolución (SLA)

  syncedAt DateTime @default(now())

  @@unique([accountId, glpiTicketId])
  @@index([accountId])
  @@index([category])
  @@map("glpi_ticket_facts")
}

// ─── ENTREGABLES / VALOR AGREGADO ─────────────────────────────────────────────────
// Regla recurrente de un entregable por cliente (ej. "Informe de gestión de mesa"
// mensual). proximaEntrega = próximo vencimiento; al marcar entregado se registra un
// DeliverableLog y se avanza al siguiente período según la frecuencia.
model Deliverable {
  id        String  @id @default(cuid())
  accountId String
  account   Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  nombre             String // "Informe de gestión de mesa"
  categoria          String? // agrupación opcional (área/línea)
  frecuencia         String // Mensual | Bimensual | Trimestral | Semestral | Anual | Única vez | ...
  responsable        String? // CSM responsable
  proximaEntrega     DateTime?
  ultimaEntrega      DateTime?
  notificarDiasAntes Int       @default(5)
  activo             Boolean   @default(true)
  notas              String?

  createdon  DateTime @default(now())
  modifiedon DateTime @updatedAt

  logs DeliverableLog[]

  @@index([accountId])
  @@map("deliverables")
}

model DeliverableLog {
  id            String      @id @default(cuid())
  deliverableId String
  deliverable   Deliverable @relation(fields: [deliverableId], references: [id], onDelete: Cascade)

  entregadoOn  DateTime @default(now())
  periodo      String? // etiqueta del período entregado (ej. "2026-07")
  entregadoPor String?
  nota         String?
  createdon    DateTime @default(now())

  @@index([deliverableId])
  @@map("deliverable_logs")
}

// ─── EMBEDDINGS DE TICKETS (búsqueda semántica) ──────────────────────────────────
// Vector del asunto+descripción de cada ticket, guardado como JSON. La similitud
// (coseno) se calcula en el servidor al buscar. textHash evita re-embeddear si el
// texto del ticket no cambió desde la última indexación.
model TicketEmbedding {
  id           String  @id @default(cuid())
  accountId    String
  account      Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
  glpiTicketId Int
  vector       String // JSON: number[]
  dim          Int
  model        String // deployment de embeddings usado
  textHash     String // hash del texto indexado
  createdon    DateTime @default(now())

  @@unique([accountId, glpiTicketId])
  @@index([accountId])
  @@map("ticket_embeddings")
}

// ─── CATÁLOGO DE SERVICIOS BEXT (lo que BEXT OFRECE, por unidad) ──────────────────
// Distinto de ProductService (lo que el cliente YA tiene). Alimenta el upsell y la
// asociación oportunidad→servicio. Se siembra desde el Excel del portafolio.
model ServiceCatalogItem {
  id             String  @id @default(cuid())
  unidad         String // Producto | Aplicaciones | Plataformas | CSU | Managed Services
  linea          String? // sub-línea (ej. Experiencias Digitales, Inteligencia de Datos)
  nombre         String
  nombreCompleto String?
  categoria      String?
  descripcion    String? // qué ofrece
  componentes    String? // cómo funciona / tecnologías
  activo         Boolean @default(true)

  opportunities OpportunityRecommendation[]

  @@unique([unidad, nombre])
  @@map("service_catalog")
}

// ─── REUNIONES DE TEAMS (caché de Graph + transcripción/notas IA) ────────────────
model TeamsMeetingCache {
  id        String  @id @default(cuid())
  accountId String
  account   Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  iCalUId            String
  subject            String
  startAt            DateTime?
  endAt              DateTime?
  organizer          String?
  organizerEmail     String?
  isOnline           Boolean   @default(false)
  joinUrl            String?
  webLink            String?
  bextParticipants   String? // JSON [{name,email}]
  clientParticipants String? // JSON [{name,email}]

  // 8b — contenido y análisis de la reunión
  transcript  String? // texto de la transcripción (si disponible)
  aiNotes     String? // JSON: notas/action items de Copilot
  analisis    String? // JSON: análisis IA (necesidades, sentimiento, oportunidades)
  analizadoOn DateTime?

  syncedAt DateTime @default(now())

  @@unique([accountId, iCalUId])
  @@index([accountId])
  @@map("teams_meetings")
}

// ─── INSIGHTS: chat persistente (tipo Copilot) + hallazgos guardados ─────────────
model InsightThread {
  id         String   @id @default(cuid())
  accountId  String
  account    Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  title      String?
  createdBy  String? // correo del CSM
  createdon  DateTime @default(now())
  modifiedon DateTime @updatedAt

  messages InsightMessage[]

  @@index([accountId])
  @@map("insight_threads")
}

model InsightMessage {
  id        String        @id @default(cuid())
  threadId  String
  thread    InsightThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  role      String // user | assistant
  content   String
  createdon DateTime      @default(now())

  @@index([threadId])
  @@map("insight_messages")
}

// ─── TAREAS y PLAYBOOKS de Customer Success ──────────────────────────────────────
// Task: unidad de trabajo del CSM (checklist). origen distingue si nació manual,
// de una acción sugerida por IA, o de un playbook aplicado.
// PlaybookRun: instancia de un playbook (plantilla) aplicado a un cliente; agrupa
// las tareas que generó, para dar seguimiento al plan (recuperación, renovación…).
model PlaybookRun {
  id         String   @id @default(cuid())
  accountId  String
  account    Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  plantilla  String // key del template (ej. recuperacion | renovacion | onboarding)
  titulo     String
  estado     String   @default("Activo") // Activo | Completado | Cancelado
  motivo     String? // por qué se aplicó (ej. "cliente en rojo: satisfacción baja")
  createdBy  String? // correo del CSM
  createdon  DateTime @default(now())
  modifiedon DateTime @updatedAt

  tasks Task[]

  @@index([accountId])
  @@map("playbook_runs")
}

model Task {
  id            String       @id @default(cuid())
  accountId     String
  account       Account      @relation(fields: [accountId], references: [id], onDelete: Cascade)
  playbookRunId String?
  playbookRun   PlaybookRun? @relation(fields: [playbookRunId], references: [id], onDelete: SetNull)

  titulo      String
  detalle     String?
  responsable String? // nombre o correo del responsable
  prioridad   String? // Alta | Media | Baja
  estado      String    @default("Pendiente") // Pendiente | En progreso | Hecha | Descartada
  vence       DateTime?
  origen      String    @default("Manual") // Manual | IA | Playbook
  createdBy   String? // correo del CSM que la creó/aprobó
  completadaOn DateTime?
  createdon   DateTime  @default(now())
  modifiedon  DateTime  @updatedAt

  @@index([accountId])
  @@index([playbookRunId])
  @@map("tasks")
}

// Hallazgos generados por IA, guardados para no re-consumir tokens (se reemplazan
// al regenerar). generatedon = fecha del último análisis.
model InsightFinding {
  id            String   @id @default(cuid())
  accountId     String
  account       Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  titulo        String
  tipo          String // categoría del hallazgo (Assessment | Upsell | Riesgo | …)
  evidencia     String
  recomendacion String
  impacto       String
  confianza     String
  servicio             String? // servicio del catálogo BEXT recomendado (nombre)
  serviceCatalogItemId String? // id resuelto del catálogo (si hubo match)
  opportunityId        String? // si el CSM lo convirtió en oportunidad
  generatedBy          String?
  generatedon          DateTime @default(now())

  @@index([accountId])
  @@map("insight_findings")
}
