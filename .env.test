# Entorno de PRUEBAS. Usa un SCHEMA dedicado ("test") dentro de la misma base de
# Docker, aislado de los datos reales (public). No requiere credenciales externas:
# GLPI/Graph/OpenAI quedan como "<...>" a propósito para probar la degradación
# elegante (estados "pendiente de configurar") sin gastar tokens ni depender de red.
DATABASE_URL="postgresql://bex:bex@localhost:5433/bex_crm?schema=test"

# Auth: bypass de dev habilitado para que Playwright entre sin Azure AD.
AUTH_SECRET="test-only-secret-aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa"
AUTH_TRUST_HOST="true"
# El server de pruebas corre en 3100; fija la URL de auth para que el redirect del
# login (dev-bypass) no caiga en el 3000 del `.env` de desarrollo.
NEXTAUTH_URL="http://localhost:3100"
AUTH_URL="http://localhost:3100"
AUTH_DEV_BYPASS="true"
AUTH_DEV_BYPASS_EMAIL="test@bextsa.com"

# Secreto del sync/digest para probar los endpoints de scheduler.
ANALYTICS_SYNC_SECRET="test-sync-secret"

# Externos SIN configurar a propósito (placeholders) → modo "pendiente".
GLPI_URL="<test>"
GLPI_APP_TOKEN="<test>"
GLPI_USER_TOKEN="<test>"
GRAPH_TENANT_ID="<test>"
GRAPH_CLIENT_ID="<test>"
GRAPH_CLIENT_SECRET="<test>"
AZURE_OPENAI_ENDPOINT="<test>"
AZURE_OPENAI_API_KEY="<test>"
AZURE_OPENAI_DEPLOYMENT="<test>"
