# ─── Base de datos ───────────────────────────────────────────────────────────
# Coincide con docker-compose.yml (usuario/clave/db = bex/bex/bex_crm, host port 5433).
# En producción (Azure) usar la cadena de PostgreSQL Flexible Server con ?sslmode=require
DATABASE_URL="postgresql://bex:bex@localhost:5433/bex_crm?schema=public"

# ─── NextAuth v5 + Azure AD (Entra ID) ────────────────────────────────────────
# Generar AUTH_SECRET con:  npx auth secret   (o)  openssl rand -base64 32
AUTH_SECRET="genera-con-npx-auth-secret"

# Bypass de login solo para desarrollo local (botón "Entrar como dev").
# Déjalo en "false"/sin definir en producción — además el código lo desactiva si NODE_ENV=production.
AUTH_DEV_BYPASS="false"
# Correo del usuario dev-bypass (default dev@bextsa.com). Para probar la pestaña
# Reuniones (Graph) en local, usa un correo con buzón real en M365.
AUTH_DEV_BYPASS_EMAIL="dev@bextsa.com"

AUTH_MICROSOFT_ENTRA_ID_ID="<CLIENT_ID>"
AUTH_MICROSOFT_ENTRA_ID_SECRET="<CLIENT_SECRET>"
AUTH_MICROSOFT_ENTRA_ID_TENANT_ID="<TENANT_ID>"

# URL pública de la app (sin trailing slash). En Azure: https://bex-crm.azurewebsites.net
NEXTAUTH_URL="http://localhost:3000"

# ─── GLPI (sync de entidades → clientes) ───────────────────────────────────────
# Crear un usuario API de solo lectura en GLPI y generar su User Token.
GLPI_URL="https://glpi.tu-dominio.com"
GLPI_APP_TOKEN="<APP_TOKEN>"
GLPI_USER_TOKEN="<USER_TOKEN>"
# "true" solo si GLPI usa certificado self-signed (interno).
GLPI_INSECURE_TLS="false"
# Nombre de la entidad padre que agrupa a los clientes en GLPI (default: "Clientes Bext").
# Solo se importan las entidades que cuelgan de ésta; el resto son unidades internas.
GLPI_CLIENTS_PARENT="Clientes Bext"

# ─── Microsoft Graph (reuniones de Teams) ──────────────────────────────────────
# App-only (client credentials). Requiere un App Registration con permisos de
# APLICACIÓN "Calendars.Read" Y "User.Read.All" + consentimiento de administrador.
# Si se dejan vacíos, la app cae a las credenciales del login (AUTH_MICROSOFT_*).
# Ver DEPLOY.md → "Integración con Microsoft Teams (Graph)".
GRAPH_TENANT_ID="<TENANT_ID>"
GRAPH_CLIENT_ID="<CLIENT_ID>"
GRAPH_CLIENT_SECRET="<CLIENT_SECRET>"
# Dominio de correo de BEXT (para distinguir participantes internos). Default: bextsa.com
GRAPH_BEXT_DOMAIN="bextsa.com"

# ─── Analítica (sync GLPI → tabla de hechos) ───────────────────────────────────
# Secreto para que un scheduler (Logic App) dispare POST /api/analitica/sync por
# HTTP (header x-sync-secret). El botón manual de la UI usa la sesión.
ANALYTICS_SYNC_SECRET="<un-secreto-largo>"

# ─── Azure OpenAI (hallazgos con IA, Fase 3) ───────────────────────────────────
# Recurso Azure OpenAI con un deployment de chat (ej. gpt-4o). Si quedan vacíos,
# la pestaña Insights muestra "pendiente de configurar".
AZURE_OPENAI_ENDPOINT="https://tu-recurso.openai.azure.com"
AZURE_OPENAI_API_KEY="<API_KEY>"
AZURE_OPENAI_DEPLOYMENT="gpt-4o"
AZURE_OPENAI_API_VERSION="2024-08-01-preview"
# Deployment de embeddings para la búsqueda semántica (ej. text-embedding-3-small).
AZURE_OPENAI_EMBEDDINGS_DEPLOYMENT="<EMBEDDINGS_DEPLOYMENT>"
